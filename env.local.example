# Get your free TMDB API key (v3 auth) at:
# https://www.themoviedb.org/settings/api
#
# Copy this file to .env.local and paste your key below.
# Never commit your real .env.local file to version control.

TMDB_API_KEY=your_tmdb_v3_api_key_here

# Used to build canonical / Open Graph URLs. Set this to your
# production domain once deployed (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://randommoviegenerator.com
